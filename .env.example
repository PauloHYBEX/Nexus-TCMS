# ===========================================
# CONFIGURAÇÕES DO BANCO LOCAL
# ===========================================
# Copie este arquivo para .env e ajuste para o ambiente local
 
# URL da API local usada pelo frontend
VITE_API_URL=http://localhost:4000/api

# Modo single-tenant:
#   true  = uso local/privado: qualquer usuário logado recebe permissões master automaticamente
#   false = MODO PRODUÇÃO: permissões carregadas do banco por usuário, convites e solicitações ativos
# Para produção multi-tenant defina VITE_SINGLE_TENANT=false no arquivo .env.local (não versionado)
VITE_SINGLE_TENANT=true
 
# Caminho do banco SQLite local (criado automaticamente em /data/nexus_testing.db)
# DATABASE_PATH=./data/nexus_testing.db

# Segredo JWT da autenticação local (OBRIGATÓRIO em produção)
# Gere com: openssl rand -hex 32   ou   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Mínimo recomendado: 32 caracteres aleatórios
LOCAL_AUTH_SECRET=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# Credenciais iniciais do usuário master local (usadas apenas no primeiro bootstrap)
# ATENÇÃO: altere imediatamente após o primeiro login
LOCAL_MASTER_EMAIL=admin@example.com
LOCAL_MASTER_PASSWORD=CHANGE_ME_STRONG_PASSWORD
LOCAL_MASTER_NAME=Admin

# Origens permitidas para CORS (separadas por vírgula). Exemplo:
# ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:8080

# ===========================================
# CONFIGURAÇÕES DO SISTEMA
# ===========================================

# URL do Studio externo (reservado para uso futuro)
# VITE_STUDIO_URL=http://localhost:3000

# ===========================================
# DESENVOLVIMENTO
# ===========================================

# Porta do servidor de desenvolvimento (padrão: 8080)
# PORT=8080

# Modo de desenvolvimento
# NODE_ENV=development
