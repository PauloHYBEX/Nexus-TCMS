# ===========================================
# CONFIGURAÇÕES DO BANCO LOCAL
# ===========================================
# Copie este arquivo para .env e ajuste para o ambiente local
 
# URL da API local usada pelo frontend
VITE_API_URL=http://localhost:4000/api

# Modo single-tenant: true = todos os usuarios logados recebem permissoes master automaticamente
# false = permissoes sao carregadas do banco por usuario (requer que o role esteja configurado no perfil)
VITE_SINGLE_TENANT=true
 
# Caminho do banco SQLite local (criado automaticamente em /data/nexus_testing.db)
# DATABASE_PATH=./data/nexus_testing.db

# Segredo JWT da autenticação local
LOCAL_AUTH_SECRET=nexus-local-secret

# Credenciais iniciais do usuário master local
LOCAL_MASTER_EMAIL=paulo.santos@teste
LOCAL_MASTER_PASSWORD=050200@Pa
LOCAL_MASTER_NAME=Paulo Santos

# ===========================================
# CONFIGURAÇÕES DO SISTEMA
# ===========================================

# URL do Studio externo (reservado para uso futuro)
# VITE_STUDIO_URL=http://localhost:3000

# ===========================================
# DESENVOLVIMENTO
# ===========================================

# Porta do servidor de desenvolvimento (padrão: 8080)
# PORT=8080

# Modo de desenvolvimento
# NODE_ENV=development
